        },
        {
          "from": "code_review",
          "to": "qa_gate_human",
          "condition": {}
        },
        {
          "from": "regression_test",
          "to": "qa_gate_human",
          "condition": {}
        },
        {
          "from": "qa_gate_human",
          "to": "deployment_check",
